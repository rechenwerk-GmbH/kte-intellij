<idea-plugin>
    <id>de.rechenwerk.kte</id>
    <name>KTE</name>
    <vendor url="https://github.com/rechenwerk-GmbH/kte-intellij">rechenwerk GmbH</vendor>

    <description><![CDATA[
Support for Kotlin jte templates (<code>.kte</code>) in IntelliJ IDEA.

<h3>Features</h3>
<ul>
    <li>KTE file type support for <code>.kte</code> templates.</li>
    <li>Kotlin K2 resolve, completion, references, documentation, and diagnostics through a synthetic Kotlin model.</li>
    <li>Template navigation, parameter checks, formatting, folding, brace matching, and live templates.</li>
    <li>Deterministic source edits for selected KTE diagnostics and quick fixes.</li>
</ul>

<p>
This first standalone release uses Kotlin and IntelliJ APIs that are not all stable public plugin APIs.
It requires IntelliJ IDEA 2026.1 or newer and currently favors K2 semantic support over injected Kotlin syntax highlighting.
</p>
    ]]></description>

    <change-notes><![CDATA[
<h3>0.1.0</h3>
<ul>
    <li>First standalone KTE plugin release.</li>
    <li>Support <code>.kte</code> templates with Kotlin K2 via a synthetic Kotlin model.</li>
    <li>Register only KTE file types and actions; Java <code>.jte</code> templates stay with the original jte plugin.</li>
    <li>Known limitation: Kotlin fragment syntax highlighting does not behave like the old injected Kotlin path.</li>
</ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Kotlin Template Engine File" implementationClass="org.jusecase.jte.intellij.language.KteFileType"
                  fieldName="INSTANCE" language="KotlinTemplateEngine" extensions="kte"/>

        <lang.parserDefinition language="KotlinTemplateEngine" implementationClass="org.jusecase.jte.intellij.language.parsing.KteParserDefinition"/>
        <lang.fileViewProviderFactory language="KotlinTemplateEngine" implementationClass="org.jusecase.jte.intellij.language.KteFileViewProviderFactory"/>
        <lang.syntaxHighlighter language="KotlinTemplateEngine" implementationClass="org.jusecase.jte.intellij.language.KteHighlighter"/>
        <editorHighlighterProvider filetype="Kotlin Template Engine File" implementationClass="org.jusecase.jte.intellij.language.KteHighlighterProvider"/>

        <lang.elementManipulator forClass="org.jusecase.jte.intellij.language.psi.KtePsiJavaContent"
                                 implementationClass="org.jusecase.jte.intellij.language.KteKotlinContentManipulator"/>

        <lang.findUsagesProvider language="KotlinTemplateEngine"
                                 implementationClass="org.jusecase.jte.intellij.language.refactoring.KteFindUsagesProvider"/>
        <lang.documentationProvider language="KotlinTemplateEngine"
                                    implementationClass="org.jusecase.jte.intellij.language.k2.KteSyntheticKotlinDocumentationProvider"/>
        <completion.contributor language="KotlinTemplateEngine"
                                implementationClass="org.jusecase.jte.intellij.language.completion.KteCompletionContributor"/>

        <defaultLiveTemplates file="liveTemplates/kte.xml"/>
        <liveTemplateContext implementation="org.jusecase.jte.intellij.language.completion.JteContext" contextId="kte"/>
        <typedHandler implementation="org.jusecase.jte.intellij.language.completion.JteTypedActionHandler"/>

        <completion.confidence
                language="HTML"
                order="first"
                implementationClass="org.jusecase.jte.intellij.language.completion.JteHtmlCompletionConfidence"/>

        <annotator language="KotlinTemplateEngine" implementationClass="org.jusecase.jte.intellij.language.JteAnnotator"/>
        <annotator language="KotlinTemplateEngine"
                   implementationClass="org.jusecase.jte.intellij.language.k2.KteSyntheticKotlinDiagnosticAnnotator"/>
        <intentionAction>
            <className>org.jusecase.jte.intellij.language.refactoring.KteOptimizeImportsIntention</className>
            <category>KTE</category>
            <language>KotlinTemplateEngine</language>
        </intentionAction>

        <lang.commenter language="KotlinTemplateEngine" implementationClass="org.jusecase.jte.intellij.language.JteCommenter"/>
        <useScopeEnlarger implementation="org.jusecase.jte.intellij.language.refactoring.JteUseScopeEnlarger"/>

        <lang.foldingBuilder language="KotlinTemplateEngine" implementationClass="org.jusecase.jte.intellij.language.KteFoldingBuilder"/>
        <lang.braceMatcher language="KotlinTemplateEngine" implementationClass="org.jusecase.jte.intellij.language.KteBraceMatcher"/>
        <moveFileHandler implementation="org.jusecase.jte.intellij.language.refactoring.JteMoveFileHandler" id="KotlinTemplateEngine"/>

        <psi.referenceContributor implementation="org.jusecase.jte.intellij.language.JteFileReferenceContributor"/>
        <psi.referenceContributor implementation="org.jusecase.jte.intellij.language.k2.KteSyntheticKotlinReferenceContributor"
                                  language="KotlinTemplateEngine"/>
        <referencesSearch implementation="org.jusecase.jte.intellij.language.refactoring.JteTemplateParamReferencesSearcher"/>

        <lang.formatter language="KotlinTemplateEngine" implementationClass="org.jusecase.jte.intellij.language.format.KteFormattingModelBuilder"/>
        <codeStyleSettingsProvider implementation="org.jusecase.jte.intellij.language.format.KteCodeStyleSettingsProvider"/>
        <langCodeStyleSettingsProvider implementation="org.jusecase.jte.intellij.language.format.KteLanguageCodeStyleSettingsProvider"/>

        <projectService serviceImplementation="org.jusecase.jte.intellij.language.k2.KteSyntheticKotlinAnalysisContextService"/>
        <projectService serviceImplementation="org.jusecase.jte.intellij.language.k2.KteSyntheticKotlinModelService"/>
        <projectService serviceImplementation="org.jusecase.jte.intellij.language.k2.KteSyntheticKotlinSemanticService"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <actions>
        <action id="de.rechenwerk.kte.CreateKteFileAction" class="org.jusecase.jte.intellij.language.file.CreateKteFileAction">
            <add-to-group group-id="NewGroup" relative-to-action="NewHtmlFile" anchor="after"/>
        </action>
        <group id="de.rechenwerk.kte.KteToolsGroup" text="KTE" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="de.rechenwerk.kte.OpenSyntheticKotlinAction"
                    class="org.jusecase.jte.intellij.language.k2.KteOpenSyntheticKotlinAction"
                    text="Open Synthetic Kotlin for Current .kte"/>
        </group>
    </actions>

    <applicationListeners>
        <listener class="org.jusecase.jte.intellij.language.JteFileReferenceContributor$FileChangeListener"
                  topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
    </applicationListeners>
</idea-plugin>
